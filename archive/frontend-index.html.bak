<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Selfni Core</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #0f172a; color: #f1f5f9; min-height: 100vh; }
    .center { display: flex; justify-content: center; align-items: center; min-height: 100vh; }
    .card { background: #1e293b; border-radius: 12px; padding: 24px; width: 100%; max-width: 500px; }
    .card h2 { color: #38bdf8; text-align: center; margin-bottom: 24px; font-size: 24px; }
    input, select { width: 100%; padding: 10px 12px; margin-bottom: 12px; border-radius: 8px; border: 1px solid #334155; background: #0f172a; color: #f1f5f9; font-size: 14px; }
    label { display: block; margin-bottom: 4px; color: #94a3b8; font-size: 13px; }
    .btn { width: 100%; padding: 12px; background: #0ea5e9; color: #fff; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; margin-top: 4px; }
    .btn:hover { background: #0284c7; }
    .btn-sm { padding: 8px 16px; background: #334155; color: #f1f5f9; border: none; border-radius: 8px; cursor: pointer; }
    .btn-danger { background: #ef4444; }
    .error { color: #ef4444; text-align: center; margin-bottom: 12px; font-size: 14px; }
    .success { color: #22c55e; margin-bottom: 12px; font-size: 14px; }
    .page { padding: 16px; max-width: 700px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
    .tile { background: #1e293b; border-radius: 12px; padding: 32px 16px; text-align: center; cursor: pointer; border: 2px solid transparent; font-size: 18px; color: #f1f5f9; }
    .tile:hover { border-color: #0ea5e9; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 12px; }
    th, td { padding: 8px; border-bottom: 1px solid #334155; text-align: center; }
    th { color: #94a3b8; }
    .badge { padding: 2px 8px; border-radius: 12px; font-size: 12px; }
    .badge-active { background: #064e3b; color: #22c55e; }
    .badge-closed { background: #1e293b; color: #94a3b8; }
    .badge-restructured { background: #1c1917; color: #f59e0b; }
    .debt-card { background: #0f172a; border-radius: 8px; padding: 12px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
    .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    .summary-item { background: #0f172a; border-radius: 8px; padding: 12px; text-align: center; }
    .summary-item .val { font-size: 20px; color: #38bdf8; font-weight: bold; }
    .summary-item .lbl { font-size: 12px; color: #94a3b8; margin-top: 4px; }
    #msg { display: none; }
  </style>
</head>
<body>

<!-- Login -->
<div id="login" class="center">
  <div class="card">
    <h2>🏦 Selfni Core</h2>
    <div id="login-error" class="error"></div>
    <label>البريد الإلكتروني</label>
    <input id="email" type="email" placeholder="hossam@selfni.com">
    <label>كلمة المرور</label>
    <input id="password" type="password" placeholder="••••••••">
    <button class="btn" onclick="login()">تسجيل الدخول</button>
  </div>
</div>

<!-- Dashboard -->
<div id="dashboard" class="page" style="display:none">
  <div class="header">
    <h2>🏦 Selfni Core</h2>
    <button class="btn-sm btn-danger" onclick="logout()">خروج</button>
  </div>
  <div class="grid">
    <div class="tile" onclick="showView('new-debt')">➕<br>دين جديد</div>
    <div class="tile" onclick="loadStatement()">📊<br>كشف الحساب</div>
    <div class="tile" onclick="showView('calc-waterfall')">💧<br>توزيع دفعة</div>
    <div class="tile" onclick="showView('calc-interest')">📈<br>حساب فائدة</div>
    <div class="tile" onclick="loadOverdue()" style="border-color:#ef4444;color:#ef4444">🔴<br>الأقساط المتأخرة</div>
    <div class="tile" onclick="loadOverdue()" style="border-color:#ef4444">🔴<br>الأقساط المتأخرة</div>
  </div>
</div>

<!-- New Debt -->
<div id="new-debt" class="page" style="display:none">
  <div class="header">
    <h2>➕ دين جديد</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div class="card">
    <div id="debt-error" class="error"></div>
    <div id="debt-success" class="success"></div>
    <label>المبلغ (جنيه)</label>
    <input id="d-principal" type="number" placeholder="10000">
    <label>الفائدة السنوية (%)</label>
    <input id="d-rate" type="number" step="0.01" placeholder="12">
    <label>عدد الأشهر</label>
    <input id="d-months" type="number" placeholder="12">
    <label>نوع الجدول</label>
    <select id="d-type">
      <option value="DECLINING">متناقص</option>
      <option value="FLAT">ثابت</option>
      <option value="BALLOON">بالون</option>
    </select>
    <label>تاريخ البداية</label>
    <input id="d-start" type="date">
    <button class="btn" onclick="createDebt()">إنشاء الدين</button>
    <div id="debt-result"></div>
  </div>
</div>

<!-- Statement -->
<div id="statement" class="page" style="display:none">
  <div class="header">
    <h2>📊 كشف الحساب</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div id="statement-content"></div>
</div>

<!-- Waterfall Calculator -->
<div id="calc-waterfall" class="page" style="display:none">
  <div class="header">
    <h2>💧 توزيع دفعة</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div class="card">
    <div id="wf-error" class="error"></div>
    <label>مبلغ الدفعة (قرش)</label>
    <input id="wf-payment" type="number" placeholder="200000">
    <label>غرامات متبقية (قرش)</label>
    <input id="wf-penalties" type="number" placeholder="5000">
    <label>فوائد متبقية (قرش)</label>
    <input id="wf-interest" type="number" placeholder="10000">
    <label>أصل متبقي (قرش)</label>
    <input id="wf-principal" type="number" placeholder="1000000">
    <label>العملة</label>
    <input id="wf-currency" type="text" value="EGP">
    <button class="btn" onclick="calcWaterfall()">احسب التوزيع</button>
    <div id="wf-result"></div>
  </div>
</div>

<!-- Interest Calculator -->
<div id="calc-interest" class="page" style="display:none">
  <div class="header">
    <h2>📈 حساب الفائدة</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div class="card">
    <div id="int-error" class="error"></div>
    <label>الأصل (قرش)</label>
    <input id="int-principal" type="number" placeholder="1000000">
    <label>الفائدة السنوية (%)</label>
    <input id="int-rate" type="number" step="0.01" placeholder="12">
    <label>عدد الأيام</label>
    <input id="int-days" type="number" placeholder="30">
    <label>العملة</label>
    <input id="int-currency" type="text" value="EGP">
    <button class="btn" onclick="calcInterest()">احسب الفائدة</button>
    <div id="int-result"></div>
  </div>
</div>

<script>
const API = "http://localhost:3011";
let TOKEN = localStorage.getItem("token") ?? "";

function getHeaders() {
  return { "Content-Type": "application/json", "Authorization": `Bearer ${TOKEN}` };
}

async function api(method, path, body) {
  const res = await fetch(API + path, {
    method,
    headers: getHeaders(),
    body: body ? JSON.stringify(body) : undefined
  });
  return res.json();
}

function showView(id) {
  ["login","dashboard","new-debt","statement","calc-waterfall","calc-interest","overdue"]
    .forEach(v => document.getElementById(v).style.display = "none");
  document.getElementById(id).style.display = id === "login" ? "flex" : "block";
}

async function login() {
  const email    = document.getElementById("email").value;
  const password = document.getElementById("password").value;
  const res = await fetch(API + "/auth/login", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ email, password })
  });
  const data = await res.json();
  if (data.token) {
    TOKEN = data.token;
    localStorage.setItem("token", TOKEN);
    showView("dashboard");
  } else {
    document.getElementById("login-error").textContent = data.error ?? "خطأ";
  }
}

function logout() {
  localStorage.clear(); TOKEN = "";
  showView("login");
}

async function createDebt() {
  document.getElementById("debt-error").textContent = "";
  document.getElementById("debt-success").textContent = "";
  const data = await api("POST", "/debts", {
    userId:         "USER-001",
    principalCents: Number(document.getElementById("d-principal").value) * 100,
    currency:       "EGP",
    annualRateBps:  Number(document.getElementById("d-rate").value) * 100,
    termMonths:     Number(document.getElementById("d-months").value),
    amortType:      document.getElementById("d-type").value,
    startDate:      document.getElementById("d-start").value,
  });
  if (data.error) {
    document.getElementById("debt-error").textContent = data.error;
    return;
  }
  document.getElementById("debt-success").textContent =
    `✓ تم إنشاء الدين | إجمالي الفوائد: ${(data.totals.totalInterest/100).toFixed(2)} جنيه | إجمالي الدفع: ${(data.totals.totalPayment/100).toFixed(2)} جنيه`;

  const rows = data.schedule.map(r => `
    <tr>
      <td>${r.installmentNumber}</td>
      <td>${r.dueDate}</td>
      <td>${(r.principalCents/100).toFixed(0)}</td>
      <td>${(r.interestCents/100).toFixed(0)}</td>
      <td>${(r.totalPaymentCents/100).toFixed(0)}</td>
      <td>${(r.remainingBalanceCents/100).toFixed(0)}</td>
    </tr>`).join("");

  document.getElementById("debt-result").innerHTML = `
    <table>
      <thead><tr><th>#</th><th>التاريخ</th><th>أصل</th><th>فائدة</th><th>إجمالي</th><th>رصيد</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

async function loadStatement() {
  showView("statement");
  const data = await api("GET", "/statement/USER-001");
  if (data.error) {
    document.getElementById("statement-content").innerHTML = `<p class="error">${data.error}</p>`;
    return;
  }
  const s = data.summary;
  const debtsHtml = data.debts.map(d => `
    <div class="debt-card">
      <div>
        <b>${(d.principalCents/100).toFixed(0)} جنيه</b>
        <span style="color:#94a3b8;font-size:13px"> — ${d.amortType} — ${d.annualRateBps/100}% — ${d.termMonths} شهر</span>
      </div>
      <span class="badge badge-${d.status.toLowerCase()}">${d.status}</span>
    </div>`).join("");

  const upcoming = (data.upcomingInstallments ?? []).map(u => `
    <p>📅 ${new Date(u.dueDate).toLocaleDateString("ar-EG")} — ${(u.totalPaymentCents/100).toFixed(0)} جنيه</p>
  `).join("");

  document.getElementById("statement-content").innerHTML = `
    <div class="summary-grid">
      <div class="summary-item"><div class="val">${s.totalDebts}</div><div class="lbl">إجمالي الديون</div></div>
      <div class="summary-item"><div class="val">${s.activeDebts}</div><div class="lbl">ديون نشطة</div></div>
      <div class="summary-item"><div class="val">${(s.totalPrincipalCents/100).toFixed(0)}</div><div class="lbl">إجمالي الأصول (جنيه)</div></div>
      <div class="summary-item"><div class="val">${(s.remainingBalance/100).toFixed(0)}</div><div class="lbl">الرصيد المتبقي (جنيه)</div></div>
    </div>
    <div class="card" style="margin-bottom:16px">
      <h3 style="margin-bottom:12px">الديون</h3>
      ${debtsHtml}
    </div>
    ${upcoming ? `<div class="card"><h3 style="margin-bottom:12px">الأقساط القادمة</h3>${upcoming}</div>` : ""}
  `;
}

async function calcWaterfall() {
  document.getElementById("wf-error").textContent = "";
  const data = await api("POST", "/calculate/waterfall", {
    paymentCents:   Number(document.getElementById("wf-payment").value),
    penaltiesCents: Number(document.getElementById("wf-penalties").value),
    interestCents:  Number(document.getElementById("wf-interest").value),
    principalCents: Number(document.getElementById("wf-principal").value),
    currency:       document.getElementById("wf-currency").value,
  });
  if (data.error) { document.getElementById("wf-error").textContent = data.error; return; }
  const a = data.allocated;
  document.getElementById("wf-result").innerHTML = `
    <div style="margin-top:16px;background:#0f172a;border-radius:8px;padding:16px">
      <p>🔴 غرامات: <b>${(a.penalties/100).toFixed(2)} جنيه</b></p>
      <p>🟡 فوائد:  <b>${(a.interest/100).toFixed(2)} جنيه</b></p>
      <p>🟢 أصل:    <b>${(a.principal/100).toFixed(2)} جنيه</b></p>
      <p>⚪ باقي:   <b>${(a.remaining/100).toFixed(2)} جنيه</b></p>
    </div>`;
}

async function calcInterest() {
  document.getElementById("int-error").textContent = "";
  const data = await api("POST", "/calculate/interest", {
    principalCents: Number(document.getElementById("int-principal").value),
    annualRateBps:  Number(document.getElementById("int-rate").value) * 100,
    days:           Number(document.getElementById("int-days").value),
    currency:       document.getElementById("int-currency").value,
  });
  if (data.error) { document.getElementById("int-error").textContent = data.error; return; }
  document.getElementById("int-result").innerHTML = `
    <div style="margin-top:16px;background:#0f172a;border-radius:8px;padding:16px;text-align:center">
      <div style="font-size:28px;color:#38bdf8;font-weight:bold">${data.display}</div>
      <div style="color:#94a3b8;font-size:13px;margin-top:4px">${data.interestCents} قرش</div>
    </div>`;
}

async function loadOverdue() {
  showView("overdue");
  const [summary, items] = await Promise.all([
    api("GET", "/dashboard/overdue-summary"),
    api("GET", "/dashboard/overdue")
  ]);

  document.getElementById("overdue-summary").innerHTML = `
    <div class="summary-item"><div class="val" style="color:#ef4444">${summary.overdue_count}</div><div class="lbl">أقساط متأخرة</div></div>
    <div class="summary-item"><div class="val" style="color:#ef4444">${(summary.overdue_amount_cents/100).toFixed(0)}</div><div class="lbl">إجمالي المتأخر (جنيه)</div></div>
    <div class="summary-item"><div class="val">${summary.average_days_late}</div><div class="lbl">متوسط التأخير (يوم)</div></div>
    <div class="summary-item"><div class="val">${summary.max_days_late}</div><div class="lbl">أقصى تأخير (يوم)</div></div>
  `;

  const rows = items.map(i => `
    <tr>
      <td>${i.installment_number}</td>
      <td>${new Date(i.due_date).toLocaleDateString("ar-EG")}</td>
      <td style="color:#ef4444">${i.days_late} يوم</td>
      <td>${(i.total_payment_cents/100).toFixed(0)} جنيه</td>
      <td>${(i.remaining_balance_cents/100).toFixed(0)} جنيه</td>
      <td>${i.user_id}</td>
    </tr>`).join("");

  document.getElementById("overdue-content").innerHTML = `
    <div class="card">
      <table>
        <thead><tr><th>#</th><th>الاستحقاق</th><th>التأخير</th><th>القسط</th><th>الرصيد المتبقي</th><th>العميل</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

async function loadOverdue() {
  showView("overdue");
  const [summary, items] = await Promise.all([
    api("GET", "/dashboard/overdue-summary"),
    api("GET", "/dashboard/overdue")
  ]);

  document.getElementById("overdue-summary").innerHTML = `
    <div class="summary-item"><div class="val" style="color:#ef4444">${summary.overdue_count}</div><div class="lbl">أقساط متأخرة</div></div>
    <div class="summary-item"><div class="val" style="color:#ef4444">${(summary.overdue_amount_cents/100).toFixed(0)}</div><div class="lbl">إجمالي المتأخر (جنيه)</div></div>
    <div class="summary-item"><div class="val">${summary.average_days_late}</div><div class="lbl">متوسط التأخير (يوم)</div></div>
    <div class="summary-item"><div class="val">${summary.max_days_late}</div><div class="lbl">أقصى تأخير (يوم)</div></div>
  `;

  const rows = items.map(i => `
    <tr>
      <td>${i.installment_number}</td>
      <td>${new Date(i.due_date).toLocaleDateString("ar-EG")}</td>
      <td style="color:#ef4444">${i.days_late} يوم</td>
      <td>${(i.total_payment_cents/100).toFixed(0)} جنيه</td>
      <td>${(i.remaining_balance_cents/100).toFixed(0)} جنيه</td>
      <td>${i.user_id}</td>
    </tr>`).join("");

  document.getElementById("overdue-content").innerHTML = `
    <div class="card">
      <table>
        <thead><tr><th>#</th><th>الاستحقاق</th><th>التأخير</th><th>القسط</th><th>الرصيد المتبقي</th><th>العميل</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

async function loadOverdue() {
  showView("overdue");
  const [summary, items] = await Promise.all([api("GET","/dashboard/overdue-summary"),api("GET","/dashboard/overdue")]);
  document.getElementById("overdue-summary").innerHTML =
    `<div class="summary-item"><div class="val" style="color:#ef4444">${summary.overdue_count}</div><div class="lbl">أقساط متأخرة</div></div>`+
    `<div class="summary-item"><div class="val" style="color:#ef4444">${(summary.overdue_amount_cents/100).toFixed(0)}</div><div class="lbl">إجمالي المتأخر (جنيه)</div></div>`+
    `<div class="summary-item"><div class="val">${summary.average_days_late}</div><div class="lbl">متوسط التأخير (يوم)</div></div>`+
    `<div class="summary-item"><div class="val">${summary.max_days_late}</div><div class="lbl">أقصى تأخير (يوم)</div></div>`;
  const rows = items.map(i=>`<tr><td>${i.installment_number}</td><td>${new Date(i.due_date).toLocaleDateString("ar-EG")}</td><td style="color:#ef4444">${i.days_late} يوم</td><td>${(i.total_payment_cents/100).toFixed(0)} ج</td><td>${(i.remaining_balance_cents/100).toFixed(0)} ج</td><td>${i.user_id}</td></tr>`).join("");
  document.getElementById("overdue-content").innerHTML=`<div class="card" style="max-width:100%"><table><thead><tr><th>#</th><th>الاستحقاق</th><th>التأخير</th><th>القسط</th><th>المتبقي</th><th>العميل</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

// Auto-login if token exists
if (TOKEN) showView("dashboard");
</script>
<div id="overdue" class="page" style="display:none">
  <div class="header">
    <h2 style="color:#ef4444">🔴 الأقساط المتأخرة</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div id="overdue-summary" class="summary-grid" style="margin-bottom:16px"></div>
  <div id="overdue-content"></div>
</div>
<div id="overdue" class="page" style="display:none">
  <div class="header">
    <h2 style="color:#ef4444">🔴 الأقساط المتأخرة</h2>
    <button class="btn-sm" onclick="showView('dashboard')">رجوع</button>
  </div>
  <div id="overdue-summary" class="summary-grid"></div>
  <div id="overdue-content"></div>
</div>
</body>
</html>
