{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --allow-all --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-all",
    "test:kernel": "deno test --allow-all src/kernel/",
    "test:domain": "deno test --allow-all src/domain/",
    "test:app": "deno test --allow-all src/application/",
    "test:infra": "deno test --allow-all src/infrastructure/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/main.ts",
    "typecheck": "deno check **/*.ts",
    "arch:check": "deno run --allow-read scripts/arch-check.ts",
    "arch:full": "deno run --allow-read scripts/full-check.ts",
    "uat": "deno run --allow-all scripts/ts/uat_full_cycle.ts",
    "build": "deno bundle src/main.ts dist/bundle.js"
  },
  "importMap": "./import_map.json",
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable", "dom"],
    "strict": true
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["archive/", "backups/", "dist/"]
  }
}
