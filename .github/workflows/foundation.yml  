name: Foundation

on:
  workflow_dispatch:
  push:
    branches:
      - main
      - develop
    paths:
      - 'src/domain/**'
      - 'src/application/**'
      - '.github/workflows/foundation.yml'
  pull_request:
    paths:
      - 'src/domain/**'
      - 'src/application/**'
      - '.github/workflows/foundation.yml'

jobs:
  foundation:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install
        run: npm ci

      - name: Lint
        run: npm run lint

      - name: Test
        run: npm test







