{
  "name": "gfos-core",
  "version": "0.5.0",
  "description": "Global Financial Operations Platform — debt management, payments, installments, ledger accounting, multi-tenant SaaS.",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "deno task dev",
    "start": "deno task start",
    "test": "deno task test",
    "test:kernel": "deno task test:kernel",
    "test:domain": "deno task test:domain",
    "test:app": "deno task test:app",
    "test:infra": "deno task test:infra",
    "lint": "deno task lint",
    "fmt": "deno task fmt",
    "fmt:check": "deno task fmt:check",
    "check": "deno task check",
    "typecheck": "deno task typecheck",
    "arch:check": "deno task arch:check",
    "arch:full": "deno task arch:full",
    "uat": "deno task uat",
    "build": "deno task build",
    "db:migrate": "psql -d gfos -f db/schema.sql",
