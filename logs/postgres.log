2026-06-07 02:41:09.480 EET [21476] STATEMENT:  
	CREATE OR REPLACE VIEW view_overdue_report AS
	SELECT
	    s.id                      AS installment_id,
	    s.installment_number,
	    s.due_date,
	    s.principal_cents,
	    s.interest_cents,
	    s.total_payment_cents,
	    s.remaining_balance_cents,
	    s.status,
	    d.user_id,
	    d.currency,
	    (CURRENT_DATE - s.due_date) AS days_late,
	    e.created_at              AS event_recorded_at
	FROM amortization_schedule s
	JOIN debt_agreements d ON d.id = s.debt_id
	JOIN financial_events e
	  ON (e.payload->>'installmentId')::uuid = s.id
	 AND e.event_type = 'InstallmentOverdue'
	WHERE s.status = 'OVERDUE';
	
