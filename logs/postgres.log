2026-06-08 07:51:28.753 EET [9832] ERROR:  column p.created_at does not exist at character 76
2026-06-08 07:51:28.753 EET [9832] HINT:  Perhaps you meant to reference the column "d.created_at".
2026-06-08 07:51:28.753 EET [9832] STATEMENT:  
	CREATE VIEW analytics_monthly_collections AS
	SELECT
	  DATE_TRUNC('month', p.created_at)     AS month,
	  d.user_id                             AS tenant_id,
	  COUNT(p.id)                           AS payment_count,
	  SUM(p.amount_cents)                   AS total_collected_cents,
	  SUM(p.principal_cents)                AS principal_collected_cents,
	  SUM(p.interest_cents)                 AS interest_collected_cents
	FROM payments p
	JOIN debt_agreements d ON d.id = p.debt_id
	GROUP BY DATE_TRUNC('month', p.created_at), d.user_id
	ORDER BY month DESC;
	
