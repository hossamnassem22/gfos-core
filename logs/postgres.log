2026-06-07 20:42:57.710 EET [30742] ERROR:  cannot change name of view column "name" to "tenant_id"
2026-06-07 20:42:57.710 EET [30742] HINT:  Use ALTER VIEW ... RENAME COLUMN ... to change name of view column instead.
2026-06-07 20:42:57.710 EET [30742] STATEMENT:  
	CREATE OR REPLACE VIEW customer_portfolio_summary AS
	SELECT
	  c.id                                    AS customer_id,
	  c.tenant_id,
	  c.name,
	  c.phone,
	  c.national_id,
	  c.created_at,
	  COUNT(DISTINCT d.id)                    AS debt_count,
	  COALESCE(SUM(d.principal_cents), 0)     AS total_principal_cents,
	  COALESCE(SUM(s.remaining), 0)           AS remaining_balance_cents,
	  COALESCE(SUM(s.overdue_amount), 0)      AS overdue_amount_cents,
	  COALESCE(SUM(s.overdue_count), 0)       AS overdue_installments
	FROM customers c
	LEFT JOIN debt_agreements d ON d.customer_id = c.id
	LEFT JOIN LATERAL (
	  SELECT
	    SUM(total_payment_cents) FILTER (WHERE status = 'OVERDUE') AS overdue_amount,
	    COUNT(*)                 FILTER (WHERE status = 'OVERDUE') AS overdue_count,
	    SUM(remaining_balance_cents) FILTER (WHERE status != 'PAID' AND installment_number = (
	      SELECT MAX(installment_number) FROM amortization_schedule WHERE debt_id = d.id
	    )) AS remaining
	  FROM amortization_schedule
	  WHERE debt_id = d.id
	) s ON true
	GROUP BY c.id, c.tenant_id, c.name, c.phone, c.national_id, c.created_at;
	
